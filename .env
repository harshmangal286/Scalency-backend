# -------------------------------------------------------
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# -------------------------------------------------------

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/scalency

# Redis connection string (used by Celery broker + backend)
REDIS_URL=redis://redis:6379

# OpenRouter API key – required for AI listing generation
# Get yours at https://openrouter.ai/
OPENROUTER_API_KEY=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

# Claude API key (fallback if OpenRouter unavailable) – OPTIONAL
# Get yours at https://console.anthropic.com/
CLAUDE_API_KEY=

# Claude API Custom Endpoint (optional, defaults to https://api.anthropic.com/v1)
# Use this if you're using a proxy, self-hosted instance, or alternative provider
# ANTHROPIC_BASE_URL=https://your-custom-endpoint.com/v1


# Flask-style secret key – change to a long random string in production
SECRET_KEY=change-me-in-production

# Optional overrides
# OPENROUTER_MODEL=openai/gpt-4o-mini
# DEBUG=false
