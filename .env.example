# -------------------------------------------------------
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# -------------------------------------------------------

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/scalency

# Redis connection string (used by Celery broker + backend)
REDIS_URL=redis://redis:6379

# OpenRouter API key – required for AI listing generation
# Get yours at https://openrouter.ai/
OPENROUTER_API_KEY="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"

# Flask-style secret key – change to a long random string in production
SECRET_KEY=change-me-in-production

# Optional overrides
# OPENROUTER_MODEL=openai/gpt-4o-mini
# DEBUG=false
