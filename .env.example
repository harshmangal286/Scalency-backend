# -------------------------------------------------------
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# -------------------------------------------------------

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/scalency

# Redis connection string (used by Celery broker + backend)
REDIS_URL=redis://redis:6379

# OpenRouter API key – OPTIONAL, priority AI service
# Get yours at https://openrouter.ai/
# If not configured, will fall back to Claude API
OPENROUTER_API_KEY=

# Claude API key – OPTIONAL, fallback AI service
# Get yours at https://console.anthropic.com/
# Required only if OPENROUTER_API_KEY is not configured
CLAUDE_API_KEY=

# Flask-style secret key – change to a long random string in production
SECRET_KEY=change-me-in-production

# Optional overrides
# OPENROUTER_MODEL=openai/gpt-4o-mini
# CLAUDE_MODEL=claude-3-5-sonnet-20241022
# DEBUG=false
